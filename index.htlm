<!DOCTYPE html>
<html lang="sw">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mfumo wa Taarifa za Ardhi - Mkoa (LIS)</title>
    <!-- Tailwind CSS CDN kwa Ajili ya Muonekano wa Kisasa -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- FontAwesome kwa Ajili ya Icons za Kuvutia -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <!-- Leaflet.js CSS na JS kwa Ajili ya Ramani ya Viwanja -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
        }
        /* Kuzuia ramani kufunika vipengele vya popups */
        .leaflet-container {
            font-family: 'Plus Jakarta Sans', sans-serif !important;
        }
    </style>
</head>
<body class="bg-slate-900 text-slate-100 min-h-screen overflow-hidden">

    <!-- MFUMO MZIMA (SPA WRAPPER) -->
    <div class="flex h-screen w-screen overflow-hidden">

        <!-- 1. SIDEBAR (NAVIGESHENI YA KUSHOTO) -->
        <aside class="w-64 bg-slate-950 border-r border-slate-800 flex flex-col justify-between flex-shrink-0">
            <div>
                <!-- Nembo ya Mkoa -->
                <div class="p-6 border-b border-slate-800 flex items-center space-x-3">
                    <div class="bg-blue-600 p-2.5 rounded-lg text-white">
                        <i class="fa-solid fa-map-location-dot text-xl"></i>
                    </div>
                    <div>
                        <h1 class="font-bold text-sm tracking-wide text-white">M-ARDHI MKOA</h1>
                        <p class="text-[10px] text-slate-400 uppercase tracking-widest font-semibold">Toleo la Mkoa v1.0</p>
                    </div>
                </div>

                <!-- Watumiaji walioingia (Role Indicator) -->
                <div class="px-6 py-4 border-b border-slate-900 bg-slate-900/40 flex items-center space-x-3">
                    <div class="w-9 h-9 rounded-full bg-slate-800 border border-blue-500/30 flex items-center justify-center text-blue-400 font-bold">
                        AM
                    </div>
                    <div>
                        <h3 class="text-xs font-semibold text-white">Eng. Amina Massawe</h3>
                        <p class="text-[10px] text-emerald-400 font-medium"><i class="fa-solid fa-circle text-[7px] mr-1"></i> Mpimaji Mkuu wa Mkoa</p>
                    </div>
                </div>

                <!-- Viungo vya Kurasa (Tab Switchers) -->
                <nav class="p-4 space-y-1.5">
                    <button onclick="switchTab('dashboard')" id="btn-dashboard" class="w-full flex items-center space-x-3 px-4 py-3 rounded-lg text-sm font-medium transition-all duration-200 bg-blue-600/10 text-blue-400 border-l-4 border-blue-500">
                        <i class="fa-solid fa-chart-pie text-lg w-5"></i>
                        <span>Dashi-bodi Kuu</span>
                    </button>
                    
                    <button onclick="switchTab('map')" id="btn-map" class="w-full flex items-center space-x-3 px-4 py-3 rounded-lg text-sm font-medium transition-all duration-200 text-slate-400 hover:bg-slate-900 hover:text-slate-100">
                        <i class="fa-solid fa-earth-africa text-lg w-5"></i>
                        <span>Ramani ya Viwanja</span>
                    </button>

                    <button onclick="switchTab('add-plot')" id="btn-add-plot" class="w-full flex items-center space-x-3 px-4 py-3 rounded-lg text-sm font-medium transition-all duration-200 text-slate-400 hover:bg-slate-900 hover:text-slate-100">
                        <i class="fa-solid fa-square-plus text-lg w-5"></i>
                        <span>Sajili Kiwanja Kipya</span>
                    </button>
                </nav>
            </div>

            <!-- Taarifa ya Usalama wa Data chini ya Sidebar -->
            <div class="p-4 border-t border-slate-800">
                <div class="bg-slate-900/50 p-3 rounded-lg border border-slate-800/60 text-[11px] text-slate-400">
                    <p class="font-semibold text-slate-300 mb-1"><i class="fa-solid fa-shield-halved text-blue-500 mr-1"></i> Ulinzi Imara (Audit Log)</p>
                    Kila hatua inayofanyika inarekodiwa na Serikali ya Mkoa.
                </div>
            </div>
        </aside>

        <!-- 2. SEHEMU KUU YA MAUDHUI (MAIN CONTENT AREA) -->
        <main class="flex-grow flex flex-col overflow-hidden bg-slate-950/20">

            <!-- BAR YA JUU (TOP HEADER BAR) -->
            <header class="h-16 border-b border-slate-800 bg-slate-950 px-8 flex items-center justify-between flex-shrink-0">
                <div class="flex items-center space-x-2">
                    <span class="text-xs bg-slate-800 px-2.5 py-1 rounded-md text-slate-400 font-medium">Ofisi ya Kamishna</span>
                    <i class="fa-solid fa-chevron-right text-xs text-slate-600"></i>
                    <span id="breadcrumb-title" class="text-sm font-semibold text-slate-200">Dashi-bodi ya Uchambuzi</span>
                </div>
                
                <div class="flex items-center space-x-4">
                    <!-- Notifications -->
                    <button class="relative p-2 text-slate-400 hover:text-slate-200 transition-colors">
                        <i class="fa-solid fa-bell text-lg"></i>
                        <span class="absolute top-1 right-1 w-2.5 h-2.5 bg-red-500 rounded-full border border-slate-950"></span>
                    </button>
                    <!-- Localized Date -->
                    <div class="text-right border-l border-slate-800 pl-4 hidden md:block">
                        <p class="text-xs text-slate-400" id="current-date-sw">Toleo thabiti la Mfumo</p>
                    </div>
                </div>
            </header>

            <!-- MADIRISHA YA KURASA (TAB PAGES) -->
            <div class="flex-grow overflow-y-auto p-8 relative">

                <!-- ================== PAGE A: DASHBOARD ================== -->
                <div id="tab-dashboard" class="space-y-8 block">
                    <!-- Cards za Takwimu Kuu -->
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
                        <!-- Card 1 -->
                        <div class="bg-slate-900 p-6 rounded-2xl border border-slate-800 flex items-center space-x-4">
                            <div class="bg-blue-600/10 p-4 rounded-xl text-blue-500 text-2xl">
                                <i class="fa-solid fa-vector-square"></i>
                            </div>
                            <div>
                                <p class="text-xs text-slate-400 font-medium">Jumla ya Viwanja</p>
                                <h3 class="text-2xl font-bold text-white mt-1" id="stat-plots">14,250</h3>
                            </div>
                        </div>
                        <!-- Card 2 -->
                        <div class="bg-slate-900 p-6 rounded-2xl border border-slate-800 flex items-center space-x-4">
                            <div class="bg-emerald-600/10 p-4 rounded-xl text-emerald-500 text-2xl">
                                <i class="fa-solid fa-file-invoice"></i>
                            </div>
                            <div>
                                <p class="text-xs text-slate-400 font-medium">Hati Zilizotolewa</p>
                                <h3 class="text-2xl font-bold text-white mt-1">9,840</h3>
                            </div>
                        </div>
                        <!-- Card 3 -->
                        <div class="bg-slate-900 p-6 rounded-2xl border border-slate-800 flex items-center space-x-4">
                            <div class="bg-amber-600/10 p-4 rounded-xl text-amber-500 text-2xl">
                                <i class="fa-solid fa-coins"></i>
                            </div>
                            <div>
                                <p class="text-xs text-slate-400 font-medium">Kodi ya Pango (Mwezi Huu)</p>
                                <h3 class="text-2xl font-bold text-white mt-1">Tsh 1.25B</h3>
                            </div>
                        </div>
                        <!-- Card 4 -->
                        <div class="bg-slate-900 p-6 rounded-2xl border border-slate-800 flex items-center space-x-4">
                            <div class="bg-red-600/10 p-4 rounded-xl text-red-500 text-2xl">
                                <i class="fa-solid fa-scale-balanced"></i>
                            </div>
                            <div>
                                <p class="text-xs text-slate-400 font-medium">Migogoro Inayoshughulikiwa</p>
                                <h3 class="text-2xl font-bold text-white mt-1">42</h3>
                            </div>
                        </div>
                    </div>

                    <!-- Chati na Takwimu Ndogo -->
                    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                        <!-- Chati ya Ugawaji wa Matumizi ya Viwanja -->
                        <div class="bg-slate-900 p-6 rounded-2xl border border-slate-800 lg:col-span-2">
                            <h3 class="text-base font-bold text-white mb-6">Mwenendo wa Usajili wa Viwanja kwa Wilaya</h3>
                            
                            <div class="space-y-4">
                                <!-- Wilaya 1 -->
                                <div>
                                    <div class="flex justify-between text-xs font-semibold mb-1">
                                        <span>Morogoro Mjini</span>
                                        <span class="text-blue-400">7,240 (51%)</span>
                                    </div>
                                    <div class="w-full bg-slate-800 h-3 rounded-full overflow-hidden">
                                        <div class="bg-blue-500 h-full rounded-full" style="width: 51%"></div>
                                    </div>
                                </div>
                                <!-- Wilaya 2 -->
                                <div>
                                    <div class="flex justify-between text-xs font-semibold mb-1">
                                        <span>Kilosa</span>
                                        <span class="text-emerald-400">3,120 (22%)</span>
                                    </div>
                                    <div class="w-full bg-slate-800 h-3 rounded-full overflow-hidden">
                                        <div class="bg-emerald-500 h-full rounded-full" style="width: 22%"></div>
                                    </div>
                                </div>
                                <!-- Wilaya 3 -->
                                <div>
                                    <div class="flex justify-between text-xs font-semibold mb-1">
                                        <span>Ifakara / Kilombero</span>
                                        <span class="text-amber-400">2,340 (16%)</span>
                                    </div>
                                    <div class="w-full bg-slate-800 h-3 rounded-full overflow-hidden">
                                        <div class="bg-amber-500 h-full rounded-full" style="width: 16%"></div>
                                    </div>
                                </div>
                                <!-- Wilaya 4 -->
                                <div>
                                    <div class="flex justify-between text-xs font-semibold mb-1">
                                        <span>Mvomero</span>
                                        <span class="text-purple-400">1,550 (11%)</span>
                                    </div>
                                    <div class="w-full bg-slate-800 h-3 rounded-full overflow-hidden">
                                        <div class="bg-purple-500 h-full rounded-full" style="width: 11%"></div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Taarifa za Hivi Karibuni -->
                        <div class="bg-slate-900 p-6 rounded-2xl border border-slate-800">
                            <h3 class="text-base font-bold text-white mb-4">Shughuli za Mwisho za Mfumo</h3>
                            <div class="space-y-4 text-xs">
                                <div class="flex items-start space-x-3 pb-3 border-b border-slate-800/50">
                                    <div class="bg-emerald-500/10 p-1.5 rounded text-emerald-500 mt-0.5">
                                        <i class="fa-solid fa-check"></i>
                                    </div>
                                    <div>
                                        <p class="font-semibold text-slate-200">Kiwanja Kimesajiliwa</p>
                                        <p class="text-slate-400 text-[11px] mt-0.5">Plot No. 45 Block H, Kihonda (Morogoro Mjini)</p>
                                        <span class="text-[10px] text-slate-500">Muda: Dakika 2 zilizopita</span>
                                    </div>
                                </div>
                                <div class="flex items-start space-x-3 pb-3 border-b border-slate-800/50">
                                    <div class="bg-blue-500/10 p-1.5 rounded text-blue-500 mt-0.5">
                                        <i class="fa-solid fa-file-signature"></i>
                                    </div>
                                    <div>
                                        <p class="font-semibold text-slate-200">Hati Imeidhinishwa</p>
                                        <p class="text-slate-400 text-[11px] mt-0.5">Mmiliki: Juma J. Hamisi</p>
                                        <span class="text-[10px] text-slate-500">Muda: Dakika 15 zilizopita</span>
                                    </div>
                                </div>
                                <div class="flex items-start space-x-3">
                                    <div class="bg-amber-500/10 p-1.5 rounded text-amber-500 mt-0.5">
                                        <i class="fa-solid fa-circle-exclamation"></i>
                                    </div>
                                    <div>
                                        <p class="font-semibold text-slate-200">Kesi ya Mgogoro Imewasilishwa</p>
                                        <p class="text-slate-400 text-[11px] mt-0.5">Mvomero Block A - Mipaka inasubiri uhakiki</p>
                                        <span class="text-[10px] text-slate-500">Muda: Saa 1 lililopita</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>


                <!-- ================== PAGE B: MAP VIEW (GIS CANVAS) ================== -->
                <div id="tab-map" class="absolute inset-0 hidden">
                    <div class="flex h-full w-full">
                        <!-- Left map controls -->
                        <div class="w-80 bg-slate-900 border-r border-slate-800 flex flex-col justify-between z-[400] overflow-y-auto">
                            <div class="p-6 space-y-6">
                                <div>
                                    <h3 class="text-sm font-bold text-white uppercase tracking-wider mb-2">Chuja na Tafuta</h3>
                                    <p class="text-xs text-slate-400">Ingiza namba ya kiwanja au mmiliki kutafuta.</p>
                                </div>
                                <div class="space-y-3">
                                    <div class="relative">
                                        <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-slate-500">
                                            <i class="fa-solid fa-magnifying-glass"></i>
                                        </span>
                                        <input type="text" id="map-search-input" placeholder="Tafuta namba ya kiwanja..." class="w-full bg-slate-950 border border-slate-800 rounded-lg py-2.5 pl-9 pr-4 text-xs text-slate-200 focus:outline-none focus:border-blue-500">
                                    </div>
                                    <button onclick="handleMapSearch()" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 rounded-lg text-xs transition-colors">Tafuta Sasa</button>
                                </div>

                                <div class="border-t border-slate-800/80 pt-4 space-y-3">
                                    <h4 class="text-xs font-semibold text-slate-300">Vipengele vya Matumizi ya Ardhi:</h4>
                                    <div class="space-y-2 text-xs">
                                        <div class="flex items-center space-x-2">
                                            <span class="w-3.5 h-3.5 rounded bg-emerald-500/30 border border-emerald-500"></span>
                                            <span>Makazi</span>
                                        </div>
                                        <div class="flex items-center space-x-2">
                                            <span class="w-3.5 h-3.5 rounded bg-amber-500/30 border border-amber-500"></span>
                                            <span>Biashara</span>
                                        </div>
                                        <div class="flex items-center space-x-2">
                                            <span class="w-3.5 h-3.5 rounded bg-purple-500/30 border border-purple-500"></span>
                                            <span>Viwanda</span>
                                        </div>
                                        <div class="flex items-center space-x-2">
                                            <span class="w-3.5 h-3.5 rounded bg-blue-500/30 border border-blue-500"></span>
                                            <span>Hifadhi ya Serikali</span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="p-6 bg-slate-950 border-t border-slate-800">
                                <div id="map-metadata-box" class="space-y-3">
                                    <h4 class="text-xs font-bold text-slate-400 uppercase tracking-widest"><i class="fa-solid fa-circle-info text-blue-500 mr-1"></i> Taarifa za Eneo lililochaguliwa</h4>
                                    <div class="bg-slate-900 p-3 rounded-lg border border-slate-800/50 text-xs">
                                        <p class="text-slate-400">Bonyeza kiwanja chochote kwenye ramani ili kuona undani wake hapa.</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Main map pane -->
                        <div class="flex-grow h-full relative" id="map-parent">
                            <div id="map-canvas" class="h-full w-full"></div>
                        </div>
                    </div>
                </div>


                <!-- ================== PAGE C: ADD PLOT ================== -->
                <div id="tab-add-plot" class="hidden max-w-4xl mx-auto">
                    <div class="bg-slate-900 p-8 rounded-2xl border border-slate-800 shadow-xl">
                        <div class="border-b border-slate-800 pb-4 mb-6">
                            <h2 class="text-xl font-bold text-white">Sajili Kiwanja Kipya cha Mkoa</h2>
                            <p class="text-xs text-slate-400 mt-1">Ingiza taarifa rasmi za mmiliki pamoja na kuratibu za kijiografia (GIS data) kutoka field.</p>
                        </div>

                        <form onsubmit="handleNewPlotSubmit(event)" class="space-y-8">
                            <!-- Section 1: Taarifa za Mmiliki -->
                            <div>
                                <h3 class="text-xs font-bold text-blue-400 uppercase tracking-wider mb-4"><i class="fa-solid fa-user-check mr-1.5"></i> 1. Taarifa Binafsi za Mmiliki</h3>
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                    <div>
                                        <label class="block text-xs font-semibold text-slate-400 mb-2">Jina Kamili la Mmiliki</label>
                                        <input type="text" id="owner-name" required placeholder="Mfano: Mary Jacob Mwakyusa" class="w-full bg-slate-950 border border-slate-800 rounded-lg py-2.5 px-4 text-sm text-slate-200 focus:outline-none focus:border-blue-500">
                                    </div>
                                    <div>
                                        <label class="block text-xs font-semibold text-slate-400 mb-2">Namba ya Kitambulisho cha Taifa (NIDA)</label>
                                        <input type="text" id="owner-nida" required placeholder="Mfano: 19900112-XXXXXXXX-XXXXX" class="w-full bg-slate-950 border border-slate-800 rounded-lg py-2.5 px-4 text-sm text-slate-200 focus:outline-none focus:border-blue-500">
                                    </div>
                                </div>
                            </div>

                            <!-- Section 2: Taarifa za Kiwanja -->
                            <div class="border-t border-slate-800 pt-6">
                                <h3 class="text-xs font-bold text-blue-400 uppercase tracking-wider mb-4"><i class="fa-solid fa-location-dot mr-1.5"></i> 2. Vipimo & Maelezo ya Kiwanja</h3>
                                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                                    <div>
                                        <label class="block text-xs font-semibold text-slate-400 mb-2">Namba ya Kiwanja (Plot No.)</label>
                                        <input type="text" id="plot-no" required placeholder="Mfano: 102" class="w-full bg-slate-950 border border-slate-800 rounded-lg py-2.5 px-4 text-sm text-slate-200 focus:outline-none focus:border-blue-500">
                                    </div>
                                    <div>
                                        <label class="block text-xs font-semibold text-slate-400 mb-2">Kitalu (Block)</label>
                                        <input type="text" id="plot-block" required placeholder="Mfano: K" class="w-full bg-slate-950 border border-slate-800 rounded-lg py-2.5 px-4 text-sm text-slate-200 focus:outline-none focus:border-blue-500">
                                    </div>
                                    <div>
                                        <label class="block text-xs font-semibold text-slate-400 mb-2">Matumizi ya Ardhi</label>
                                        <select id="plot-use" class="w-full bg-slate-950 border border-slate-800 rounded-lg py-2.5 px-4 text-sm text-slate-200 focus:outline-none focus:border-blue-500">
                                            <option value="Makazi">Makazi (Residential)</option>
                                            <option value="Biashara">Biashara (Commercial)</option>
                                            <option value="Viwanda">Viwanda (Industrial)</option>
                                        </select>
                                    </div>
                                </div>
                                <div class="mt-4">
                                    <label class="block text-xs font-semibold text-slate-400 mb-2">Wilaya & Kata kilipo</label>
                                    <input type="text" id="plot-location" required placeholder="Mfano: Morogoro Mjini / Kihonda" class="w-full bg-slate-950 border border-slate-800 rounded-lg py-2.5 px-4 text-sm text-slate-200 focus:outline-none focus:border-blue-500">
                                </div>
                            </div>

                            <!-- Section 3: GIS Boundaries Simulator -->
                            <div class="border-t border-slate-800 pt-6">
                                <h3 class="text-xs font-bold text-blue-400 uppercase tracking-wider mb-2"><i class="fa-solid fa-globe mr-1.5"></i> 3. Mipaka ya Kijiografia (GIS Plot Simulation)</h3>
                                <p class="text-xs text-slate-400 mb-4">Ili kuiga kitendo cha kupakia faili kutoka GPS, chagua mojawapo ya maeneo ya majaribio yaliyosomwa hapa chini.</p>
                                
                                <div class="bg-slate-950 p-4 rounded-xl border border-slate-800/80 flex items-center justify-between">
                                    <div class="flex items-center space-x-3">
                                        <div class="bg-blue-600/10 p-2 rounded-lg text-blue-400 text-lg">
                                            <i class="fa-solid fa-file-code"></i>
                                        </div>
                                        <div>
                                            <h4 class="text-xs font-bold text-slate-200">Morogoro_Kihonda_Plot_Auto.geojson</h4>
                                            <p class="text-[10px] text-slate-400">Pikseli na polygoni zimeshasanifishwa kwa usahihi wa GPS (-6.82, 37.66)</p>
                                        </div>
                                    </div>
                                    <span class="text-xs text-emerald-400 bg-emerald-500/10 px-2.5 py-1 rounded-full font-medium"><i class="fa-solid fa-circle-check mr-1"></i> Tayari Kupakiwa</span>
                                </div>
                            </div>

                            <!-- Buttons -->
                            <div class="border-t border-slate-800 pt-6 flex justify-end space-x-4">
                                <button type="reset" class="px-5 py-2.5 bg-slate-800 hover:bg-slate-700 rounded-lg text-xs font-semibold text-slate-300 transition-colors">Futa Kila Kitu</button>
                                <button type="submit" class="px-5 py-2.5 bg-blue-600 hover:bg-blue-700 rounded-lg text-xs font-semibold text-white transition-colors shadow-lg shadow-blue-500/20"><i class="fa-solid fa-cloud-arrow-up mr-1.5"></i> Sajili Kwenye Database</button>
                            </div>
                        </form>
                    </div>
                </div>

            </div>
        </main>
    </div>

    <!-- 3. TOAST NOTIFICATIONS FOR USER ACTIONS -->
    <div id="toast-container" class="fixed bottom-6 right-6 z-[9999] transition-all duration-300 transform translate-y-20 opacity-0 pointer-events-none">
        <div class="bg-slate-900 border border-emerald-500/30 text-emerald-400 px-5 py-4 rounded-xl shadow-2xl flex items-center space-x-3">
            <div class="bg-emerald-500/10 p-2 rounded-lg text-emerald-500 text-lg">
                <i class="fa-solid fa-circle-check"></i>
            </div>
            <div>
                <h4 class="text-xs font-bold text-white" id="toast-title">Mabadiliko Yamefanikiwa</h4>
                <p class="text-[11px] text-slate-400 mt-0.5" id="toast-message">Kiwanja kimeongezwa kwenye Database na Ramani.</p>
            </div>
        </div>
    </div>


    <!-- ================== SCRIPT ZA KUONGOZA MFUMO MZIMA ================== -->
    <script>
        // Mfumo wa Tarehe kwa Kiswahili
        const dateOptions = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
        document.getElementById('current-date-sw').innerText = "Leo ni: " + new Date().toLocaleDateString('sw-TZ', dateOptions);

        let mapInstance = null;
        let plotsGroup = null;

        // Data ya Viwanja vya Kwanza vya Majaribio (Morogoro)
        let customPlotsData = [
            {
                id: 1,
                plotNo: "45",
                block: "H",
                owner: "Juma J. Hamisi",
                nida: "19840512-42110-00001",
                use: "Makazi",
                location: "Morogoro Mjini / Kihonda",
                color: "green",
                coordinates: [
                    [-6.820, 37.660],
                    [-6.820, 37.665],
                    [-6.825, 37.665],
                    [-6.825, 37.660]
                ]
            },
            {
                id: 2,
                plotNo: "12",
                block: "F",
                owner: "Neema Rashid",
                nida: "19920108-11120-00003",
                use: "Biashara",
                location: "Morogoro Mjini / Kihonda",
                color: "orange",
                coordinates: [
                    [-6.826, 37.661],
                    [-6.826, 37.667],
                    [-6.830, 37.667],
                    [-6.830, 37.661]
                ]
            }
        ];

        // 1. KUBADILI TAB MBALIMBALI (SPA NAVIGATION SIMULATOR)
        function switchTab(tabId) {
            // Ficha tabs zote
            document.getElementById('tab-dashboard').classList.add('hidden');
            document.getElementById('tab-map').classList.add('hidden');
            document.getElementById('tab-add-plot').classList.add('hidden');

            // Ondoa muonekano amilifu (active) kwenye vifungo vyote
            const btns = ['btn-dashboard', 'btn-map', 'btn-add-plot'];
            btns.forEach(id => {
                const el = document.getElementById(id);
                el.className = "w-full flex items-center space-x-3 px-4 py-3 rounded-lg text-sm font-medium transition-all duration-200 text-slate-400 hover:bg-slate-900 hover:text-slate-100";
            });

            // Onesha tab iliyochaguliwa
            document.getElementById('tab-' + tabId).classList.remove('hidden');

            // weka kitufe cha tab iliyochaguliwa kuwa active
            const activeBtn = document.getElementById('btn-' + tabId);
            activeBtn.className = "w-full flex items-center space-x-3 px-4 py-3 rounded-lg text-sm font-medium transition-all duration-200 bg-blue-600/10 text-blue-400 border-l-4 border-blue-500";

            // Badili kichwa cha ukurasa wa juu
            const titles = {
                'dashboard': 'Dashi-bodi ya Uchambuzi wa Mkoa',
                'map': 'Ramani ya Viwanja & GIS Layer',
                'add-plot': 'Kusajili Kiwanja Kipya'
            };
            document.getElementById('breadcrumb-title').innerText = titles[tabId];

            // Washa ramani kama imechaguliwa
            if (tabId === 'map') {
                setTimeout(() => {
                    initMap();
                }, 100);
            }
        }

        // 2. KUWASHA RAMANI YA MAP (MAP INITIALIZATION WITH LEAFLET)
        function initMap() {
            if (mapInstance) {
                mapInstance.invalidateSize();
                return; 
            }

            // Fungua ramani ikilenga Morogoro, Tanzania
            mapInstance = L.map('map-canvas').setView([-6.823, 37.663], 14);

            // Weka safu ya ramani kutoka OpenStreetMap
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
                maxZoom: 19
            }).addTo(mapInstance);

            plotsGroup = L.layerGroup().addTo(mapInstance);
            renderPlotsOnMap();
        }

        // 3. CHORA VIWANJA VYOTE VYENYE DATA KWENYE RAMANI
        function renderPlotsOnMap() {
            if (!plotsGroup) return;
            plotsGroup.clearLayers();

            customPlotsData.forEach(plot => {
                const strokeColor = plot.use === 'Makazi' ? '#10b981' : (plot.use === 'Biashara' ? '#f59e0b' : '#a855f7');
                const fillColor = plot.use === 'Makazi' ? '#10b981' : (plot.use === 'Biashara' ? '#f59e0b' : '#a855f7');

                const polygon = L.polygon(plot.coordinates, {
                    color: strokeColor,
                    fillColor: fillColor,
                    fillOpacity: 0.35,
                    weight: 2
                });

                // Dirisha la habari ukibofya kwenye ramani
                const popupContent = `
                    <div style="font-family: 'Plus Jakarta Sans', sans-serif;" class="text-slate-800 p-1">
                        <h4 class="font-bold text-xs" style="margin: 0 0 4px 0;">Plot No: ${plot.plotNo} / Kitalu ${plot.block}</h4>
                        <p style="font-size: 11px; margin: 0 0 2px 0;"><b>Mmiliki:</b> ${plot.owner}</p>
                        <p style="font-size: 11px; margin: 0 0 2px 0;"><b>Matumizi:</b> ${plot.use}</p>
                        <p style="font-size: 11px; margin: 0 0 2px 0;"><b>Wilaya/Kata:</b> ${plot.location}</p>
                        <span style="font-size: 10px; display: inline-block; padding: 2px 6px; background-color: #f0fdf4; color: #15803d; font-weight: bold; border-radius: 4px; margin-top: 4px;">Imesajiliwa</span>
                    </div>
                `;

                polygon.bindPopup(popupContent);

                // Tukio la Kubofya ili kusasisha maelezo ya metadata upande wa kushoto
                polygon.on('click', () => {
                    updateMapMetadataPanel(plot);
                });

                plotsGroup.addLayer(polygon);
            });
        }

        // Sasisha kisanduku cha maelezo ya kiwanja kilichobofolewa
        function updateMapMetadataPanel(plot) {
            const panel = document.getElementById('map-metadata-box');
            panel.innerHTML = `
                <h4 class="text-xs font-bold text-slate-400 uppercase tracking-widest"><i class="fa-solid fa-circle-info text-blue-500 mr-1"></i> Taarifa za Eneo</h4>
                <div class="bg-slate-950 p-4 rounded-xl border border-slate-800 space-y-3 text-xs">
                    <div>
                        <p class="text-slate-500 font-medium">Kiwanja & Kitalu</p>
                        <p class="text-sm font-bold text-white mt-0.5">Plot No: ${plot.plotNo} (Block ${plot.block})</p>
                    </div>
                    <div>
                        <p class="text-slate-500 font-medium">Mmiliki Mkuu</p>
                        <p class="text-sm font-bold text-slate-200 mt-0.5">${plot.owner}</p>
                        <p class="text-[10px] text-slate-400 mt-0.5">NIDA: ${plot.nida}</p>
                    </div>
                    <div>
                        <p class="text-slate-500 font-medium">Matumizi Rasmi</p>
                        <span class="inline-block px-2.5 py-0.5 mt-1 rounded text-[10px] font-bold ${plot.use === 'Makazi' ? 'bg-emerald-500/15 text-emerald-400' : 'bg-amber-500/15 text-amber-400'}">${plot.use}</span>
                    </div>
                    <div class="pt-2 border-t border-slate-900 flex justify-between items-center text-[10px] text-slate-500">
                        <span>${plot.location}</span>
                    </div>
                </div>
            `;
        }

        // 4. KUTAFUTA KIWANJA KWENYE RAMANI
        function handleMapSearch() {
            const val = document.getElementById('map-search-input').value.trim();
            if (!val) return;

            const found = customPlotsData.find(p => p.plotNo === val || p.owner.toLowerCase().includes(val.toLowerCase()));
            
            if (found && mapInstance) {
                // Lenga ramani kwenye coordinates za kiwanja hicho
                mapInstance.setView(found.coordinates[0], 15);
                updateMapMetadataPanel(found);
                
                // simulate click on that coordinate to open popup
                L.popup()
                    .setLatLng(found.coordinates[0])
                    .setContent(`
                        <div style="font-family: 'Plus Jakarta Sans', sans-serif;" class="text-slate-800 p-1">
                            <h4 class="font-bold text-xs" style="margin: 0 0 4px 0;">Plot No: ${found.plotNo} / Block ${found.block}</h4>
                            <p style="font-size: 11px; margin: 0;"><b>Mmiliki:</b> ${found.owner}</p>
                        </div>
                    `)
                    .openOn(mapInstance);
            } else {
                alert("Kiwanja chenye namba '" + val + "' hakijapatikana mkoani hapa. Hakikisha umeingiza taarifa sahihi.");
            }
        }

        // 5. KUPUKEA NA KUSAJILI KIWANJA KIPYA (SIMULATION OF NEW ENTRY)
        function handleNewPlotSubmit(event) {
            event.preventDefault();

            const ownerName = document.getElementById('owner-name').value;
            const ownerNida = document.getElementById('owner-nida').value;
            const plotNo = document.getElementById('plot-no').value;
            const plotBlock = document.getElementById('plot-block').value;
            const plotUse = document.getElementById('plot-use').value;
            const plotLocation = document.getElementById('plot-location').value;

            // Kuzalisha coordinates za majaribio karibu na Morogoro Kihonda kulingana na kiasi cha viwanja
            const baseLat = -6.820 - (customPlotsData.length * 0.005);
            const baseLon = 37.668 + (customPlotsData.length * 0.002);

            const newPlot = {
                id: customPlotsData.length + 1,
                plotNo: plotNo,
                block: plotBlock,
                owner: ownerName,
                nida: ownerNida,
                use: plotUse,
                location: plotLocation,
                coordinates: [
                    [baseLat, baseLon],
                    [baseLat, baseLon + 0.004],
                    [baseLat - 0.004, baseLon + 0.004],
                    [baseLat - 0.004, baseLon]
                ]
            };

            // Ongeza kwenye mlisho wa data yetu ya uigaji
            customPlotsData.push(newPlot);

            // Sasisha Dashboard Statistics kwa dhati
            document.getElementById('stat-plots').innerText = (14250 + (customPlotsData.length - 2)).toLocaleString();

            // Rangi upya viwanja kwenye ramani
            if (mapInstance) {
                renderPlotsOnMap();
            }

            // Onyesha ujumbe wa kufanikiwa (Toast Notification)
            showToast("Usajili Umekamilika", `Kiwanja No. ${plotNo} Block ${plotBlock} kimesajiliwa chini ya ${ownerName}.`);

            // Rudi kwenye Ukurasa wa Ramani uone kikiwa kimeongezeka!
            setTimeout(() => {
                switchTab('map');
                if (mapInstance) {
                    mapInstance.setView([baseLat, baseLon], 15);
                }
            }, 2500);

            // Safisha fomu
            document.querySelector('form').reset();
        }

        // Mfumo wa Kuonyesha Toasts
        function showToast(title, message) {
            const toast = document.getElementById('toast-container');
            document.getElementById('toast-title').innerText = title;
            document.getElementById('toast-message').innerText = message;

            toast.classList.remove('opacity-0', 'translate-y-20', 'pointer-events-none');
            toast.classList.add('opacity-100', 'translate-y-0');

            setTimeout(() => {
                toast.classList.remove('opacity-100', 'translate-y-0');
                toast.classList.add('opacity-0', 'translate-y-20', 'pointer-events-none');
            }, 4000);
        }
    </script>
</body>
</html>
